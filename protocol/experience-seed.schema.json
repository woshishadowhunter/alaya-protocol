{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alaya-protocol.org/schema/experience-seed-1.0.json",
  "title": "Alaya Experience Seed",
  "type": "object",
  "required": ["schema_version", "id", "lesson", "guidance", "context_tags", "applicability", "confidence", "status", "evidence", "created_at", "updated_at"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "id": {"type": "string", "minLength": 1},
    "lesson": {"type": "string", "minLength": 1},
    "guidance": {"type": "string", "minLength": 1},
    "context_tags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "applicability": {"type": "string", "minLength": 1},
    "counterexamples": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "status": {"enum": ["candidate", "active", "deprecated"]},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "last_activated_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["polarity", "source_id", "summary", "observed_at"],
      "properties": {
        "polarity": {"enum": ["support", "contradict"]},
        "source_id": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "observed_at": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
